			identifier: return.type
			count: 1
			path: src/HttpClient.php

		-
			message: '#^Parameter \#2 \$options of function curl_setopt_array expects array\{10002\: non\-empty\-string, 19913\: bool, 13\: int, 52\: bool, 68\: int, 10023\: array\<int, string\>, 10018\: non\-empty\-string\}, array\{10002\: string, 19913\: true, 13\: int, 52\: true, 68\: 3, 10023\: array\<int, string\>, 10018\: string\} given\.$#'
			identifier: argument.type
			count: 1
			path: src/HttpClient.php

