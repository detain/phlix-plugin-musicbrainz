{
    "name": "detain/phlix-plugin-musicbrainz",
    "type": "phlix-plugin",
    "description": "MusicBrainz metadata provider for Phlix — artist/album/track metadata, album art, and AcoustID integration.",
    "license": "MIT",
    "keywords": ["phlix", "phlix-plugin", "musicbrainz", "music", "metadata", "metadata-provider", "audio", "albums", "artists", "tracks", "acoustid", "discography"],
    "homepage": "https://github.com/detain/phlix-plugin-musicbrainz",
    "require": {
        "php": ">=8.3",
        "detain/phlix-shared": "^0.18.0",
        "psr/container": "^1.1 || ^2.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "repositories": [
        { "type": "vcs", "url": "https://github.com/detain/phlix-shared.git" }
    ],
    "autoload": {
        "psr-4": {
            "Phlix\\Plugin\\MusicBrainz\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phlix\\Tests\\Unit\\Plugin\\MusicBrainz\\": "tests/Unit/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
